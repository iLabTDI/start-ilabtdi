# ─────────────────────────────────────────────────────────────
# Start-Ilabtdi — Variables de entorno
# ─────────────────────────────────────────────────────────────
# Copia este archivo a `.env` y llena los valores.
# Nunca subas `.env` al repo (ya está en .gitignore).
# Solo variables prefijadas con VITE_ se exponen al cliente.

# ─── Supabase (obligatorio) ───────────────────────────────────
# Dashboard → Project Settings → API
# URL del proyecto (algo como https://xxxx.supabase.co)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# anon/public key — SEGURA para exponer al cliente (protegida por RLS)
# NUNCA uses la service_role key aquí, jamás.
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Metadata de la app (opcional) ────────────────────────────
VITE_APP_NAME="iLab TDI Starter"
VITE_APP_URL=https://ilabtdi.com
VITE_APP_VERSION=0.1.0

# ─── Supabase CLI (solo para scripts db:types:remote) ─────────
# Dashboard → Project Settings → General → Reference ID
# Este NO lleva prefijo VITE_ porque nunca se expone al cliente.
SUPABASE_PROJECT_ID=your-project-ref
